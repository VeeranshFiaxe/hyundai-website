<script defer src="/etc/designs/hyundai/ww/commonlibs/js/jquery.dotdotdot.min.js"></script>



    
    <script>
			/*
				M-00048
				IE,Chrome 둘다 ... 처리 하도록 js처리
				News Room의 Highlights 영역에 적용 <h3 class="subTit">...</h3>
			*/
			document.domain = "hyundai.com";
			$(document).ready(function(){
				if($("h3.subTit").length > 0){
					$("h3.subTit").each(function(index){
						$(this).dotdotdot({
							wrap : 'word'
						});
					});
				}
			});
			</script>

