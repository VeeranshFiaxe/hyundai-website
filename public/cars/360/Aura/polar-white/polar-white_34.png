<script type="text/javascript">
    var dep1 = null;
    var dep2 = null;
    var dep3 = null;
    var dep4 = null;
    var dep5 = null;
    $(document).ready(function(){
        gnb(dep1,dep2,dep3,dep4,dep5);

        // M-00134  모바일 국가지역 이동 스크립트 s
        var locationData = fnGetYourLocation();
        if(locationData){
            if(locationData.countryCode){
                var linkUrl = '<a href="' + Header.goToCountry.movePage(locationData.countryCode) + '" class="btn" onClick="_satellite.track(\'gnb\',\''+Granite.I18n.get("Go to your country or region")+'\')">' + Granite.I18n.get("Go to your country or region") + '</a>';

                $(".visitCountry_area .btn_position_area").prepend(linkUrl);

                $("button.btn_country").on("click", function(){ window.location = Header.goToCountry.movePage(locationData.countryCode);  });

             }

            if(locationData.countryCode && locationData.countryName){
                $(".visitCountry_area .position").prepend('<a href="' + Header.goToCountry.movePage(locationData.countryCode)+'" class="gnb_txt_btn btn_local" target="_self"><span class="pst_icon">Current location</span><span class="pst_txt">' + locationData.cityName+', ' + locationData.countryName + '</span></a>');
            }
         }
     // M-00134  모바일 국가지역 이동 스크립트 e
        var languageCode = "en";
        var langCodeArr = langCode.split("_");
        if(langCodeArr.length > 0){
            languageCode = langCodeArr[0];
        }
        $(".btnGlobal").on("click", function(){ window.location = "/worldwide/"+ languageCode +"/company/hyundai-world-wide";  }); //220914 modify : btnLanguage -> btnGlobal

        // [2021.07.08:전영우] 추천검색어, 연관검색어 추가
        // satellite 이벤트명은 hardcording.
        var search_popular_list_count = 6;

        var headPart = document.location.pathname.indexOf('/en') == -1 ? document.location.pathname.substring(0, document.location.pathname.indexOf('/ko') + 3) : document.location.pathname.substring(0, document.location.pathname.indexOf('/en') + 3);
        var mobileGnbContactUs = headPart + '/company/contact-us';
        if(document.location.port == '4502') {
            mobileGnbContactUs = mobileGnbContactUs + '.html';
        }

        $('#mGnbContactUs').attr('href', mobileGnbContactUs);

        $("#gnbMenu .dep2_a").each( function(){
            if($(this).text() == "Home" && window.innerWidth > 740) {$(this).hide();}
        });
    });

    function clickGnbMenu(link, target) {
        var isWcMobile = link.indexOf("/worldcup") > 0 && $("body").hasClass("mobile");
        if(link != '' && !isWcMobile) {
            if(target == '_blank') {
                window.open(link);
            } else {
                document.location.href = link;
            }

        }
    }

    // #58244 - GNB 해시태그 클릭 시 링크 수정 요청
    var resolvedPath = "";
    function fn_move_keyword_b(hashTag){
        var dataIsauthor = $('.gnb').attr('data-isauthor');
		var hashTag = hashTag.toLowerCase().replace("'" , "").replace(/\s|_/g,"-");

        if(dataIsauthor == "true"){
        	resolvedPath = "/content/hyundai/worldwide/"+ languageCode +"/keyword."+ hashTag + ".html";
        } else{
        	resolvedPath = "/worldwide/"+ languageCode +"/keyword."+ hashTag;
        }
    }

    function fn_move_keyword(hashTag){
    	fn_move_keyword_b(hashTag);

        if( hashTag != "" ){
            document.location.href = resolvedPath;
        }
    }

    // #58947 - 특수문자 포함 검색어를 위한 수정
   $(".topicList a").on("click", function(){

    	var word = $(this).attr("data-word");
    	var dataIsauthor = $('.gnb').attr('data-isauthor');
    	if(dataIsauthor == "true"){
    		searchResult = "/content/hyundai/worldwide/"+ languageCode +"/search.html";
        } else{
        	searchResult = "/worldwide/"+ languageCode +"/search";
        }

    	document.location.href = searchResult + "?query=" + word + "&_charset=utf-8";

    	var popularWord = "popular " + word;
    	_satellite.track('search-result', popularWord);
    });

</script>

    
