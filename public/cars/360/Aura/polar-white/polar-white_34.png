<script>
$(document).ready(function(){

    function getCookie(cname) {
        var name = cname + "=";
        var decodedCookie = decodeURIComponent(document.cookie);
        var ca = decodedCookie.split(';');
        for(var i = 0; i <ca.length; i++) {
            var c = ca[i];
            while (c.charAt(0) == ' ') {
                c = c.substring(1);
            }
            if (c.indexOf(name) == 0) {
                return c.substring(name.length, c.length);
            }
        }
    return "";
    }

    function checkForAccess(){
        $(function() {
            $.ajax({
                url         : "https://www.youtube.com/player_api",
                dataType    : "jsonp",
                timeout     : 5000,
                success : function () {
                },
                error : function (parsedjson) {
                    if(parsedjson.status == "200"){
                        //Video will be displayed
                        $(".movieContent1").css("display","block");
                        //$(".movieContent").css("display","block");
                        $(".movieContent1").css("background","#fff");
                        //$(".movieContent").css("background","#fff");
                        $(".movieContent1").css("padding","0");
                        //$(".movieContent").css("padding","0");
                    }else{
                        //Video will be blocked
                        console.log("here");
                        $(".movieContent1").css("display",      "block");
                        $(".movieContent").css("display",       "block");
                        $(".movieContent1").css("background",   "#f6f3f2");
                        $(".movieContent").css("background",    "#f6f3f2");
                        $(".movieContent1").css("padding",      "0");
                        $(".movieContent").css("padding",       "0");
                        $(".movieContent1").html(Granite.I18n.get("Youtube has been blocked by firewall. Please allow Youtube to watch the video"));
                        $(".movieContent").html(Granite.I18n.get("Youtube has been blocked by firewall. Please allow Youtube to watch the video"));
                    }
                }
            });
        });
    }


    setTimeout(function(){
        //Get the cookie value
        var cookieConcent   = getCookie("_evidon_consent_cookie");
        var categories      = window.evidon.notice._getCategoriesReturnObject();
        var isConsentGiven  = window.evidon.notice.consentIsGiven;
        //Check for language
        if( langCode == "en_gb" ){
            console.log("i am inside 0");
            //Check for cookie value 
            if( cookieConcent != null && cookieConcent != undefined && cookieConcent != "" ){
                console.log("i am inside 1");
                //This is EN site logic
                //Check if the cookie  banner is accepted 
                if( categories.functional ){
                    console.log("i am inside 2");
                    //If yes check for youtube access
                    checkForAccess();
                }else{
                    console.log("i am inside 3");
                    //Display msg for enable cookie in banner
                    $(".movieContent1").css("display",      "block");
                    $(".movieContent").css("display",       "block");
                    $(".movieContent1").css("background",   "#f6f3f2");
                    $(".movieContent").css("background",    "#f6f3f2");
                    $(".movieContent1").css("padding",      "0");
                    $(".movieContent").css("padding",       "0");
                    $(".movieContent1").html(Granite.I18n.get("Please <a href='#' id='acceptCookie' onclick='event.preventDefault(); window.evidon.notice._showConsentUI();'>accept functional cookies</a> to watch the video"));
                    $(".movieContent").html(Granite.I18n.get("Please <a href='#' id='acceptCookie' onclick='event.preventDefault(); window.evidon.notice._showConsentUI();'>accept functional cookies</a> to watch the video"));
                    /* $(".movieContent1").html(Granite.I18n.get("Please <a href='#' onclick='event.preventDefault(); window.evidon.notice._showConsentUI();'>accept publisher cookies</a> to watch the video"));
                    $(".movieContent").html(Granite.I18n.get("Please <a href='#' onclick='event.preventDefault(); window.evidon.notice._showConsentUI();'>accept publisher cookies</a> to watch the video")); */
                }
            }else if( isConsentGiven == true ){
                //Concent is opt out for CCNA
                //If yes check for youtube access
                checkForAccess();
            }else{
                console.log("i am inside 4");
                //Display msg for enable cookie in banner
                $(".movieContent1").css("display",      "block");
                $(".movieContent").css("display",       "block");
                $(".movieContent1").css("background",   "#f6f3f2");
                $(".movieContent").css("background",    "#f6f3f2");
                $(".movieContent1").css("padding",      "0");
                $(".movieContent").css("padding",       "0");
                $(".movieContent1").html(Granite.I18n.get("Please <a href='#' id='acceptCookie' onclick='event.preventDefault(); window.evidon.notice._showConsentUI();'>accept functional cookies</a> to watch the video"));
                $(".movieContent").html(Granite.I18n.get("Please <a href='#' id='acceptCookie' onclick='event.preventDefault(); window.evidon.notice._showConsentUI();'>accept functional cookies</a> to watch the video"));
                /* $(".movieContent1").html(Granite.I18n.get("Please <a href='#' onclick='event.preventDefault(); window.evidon.notice._showConsentUI();'>accept publisher cookies</a> to watch the video"));
                $(".movieContent").html(Granite.I18n.get("Please <a href='#' onclick='event.preventDefault(); window.evidon.notice._showConsentUI();'>accept publisher cookies</a> to watch the video")); */
            }
        }else{
            console.log("i am inside 5");
            //This is KO site logic
            checkForAccess();
        }
    }, 3000);

});
/* [2022.12.23 : 최재영] WW : S - evidon 쿠키 셋팅 팝업 클릭 이벤트 */
$(document).on('click','#evidon-prefdiag-accept',function(){
    window.location.reload();
});
